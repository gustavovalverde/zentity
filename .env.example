# Zentity — Docker Compose Environment Variables
# Copy to .env and fill in values. Run: cd apps/web && pnpm setup
# For local dev without Docker, see apps/web/.env.example

# ─── Required (generate with: cd apps/web && pnpm setup) ───────────────────
BETTER_AUTH_SECRET=
OPAQUE_SERVER_SETUP=
NEXT_PUBLIC_OPAQUE_SERVER_PUBLIC_KEY=
INTERNAL_SERVICE_TOKEN=

# ─── Cryptographic Secrets ──────────────────────────────────────────────────
BBS_ISSUER_SECRET=
# RECOVERY_ML_KEM_SECRET_KEY=  # Base64 ML-KEM-768 secret key (2400 bytes)
# PAIRWISE_SECRET=             # Min 32 chars, for HAIP pairwise sub

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# TRUSTED_ORIGINS=http://127.0.0.1:3000,http://[::1]:3000

# ─── Feature Flags ──────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_FHEVM=false
NEXT_PUBLIC_ENABLE_HARDHAT=false

# ─── Build-time Client Vars ────────────────────────────────────────────────
NEXT_PUBLIC_PROJECT_ID=
NEXT_PUBLIC_FHEVM_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
NEXT_PUBLIC_COOP=same-origin-allow-popups
# NEXT_PUBLIC_APP_ENV=local
# NEXT_PUBLIC_NOIR_DEBUG=true

# ─── FHE Service ────────────────────────────────────────────────────────────
FHE_BODY_LIMIT_MB=64

# ─── Blockchain — Registrar Wallets ─────────────────────────────────────────
# REGISTRAR_PRIVATE_KEY=
# LOCAL_REGISTRAR_PRIVATE_KEY=
# FHEVM_REGISTRAR_PRIVATE_KEY=

# ─── Blockchain — Contract Addresses ────────────────────────────────────────
# FHEVM_IDENTITY_REGISTRY=
# FHEVM_COMPLIANCE_RULES=
# FHEVM_COMPLIANT_ERC20=

# ─── Email ──────────────────────────────────────────────────────────────────
# MAIL_FROM_EMAIL=no-reply@zentity.local
# MAIL_FROM_NAME=Zentity
# RESEND_API_KEY=

# ─── Observability ──────────────────────────────────────────────────────────
LOG_LEVEL=debug
OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=  # Default: Docker internal otel-collector
# OTEL_EXPORTER_OTLP_HEADERS=

# ─── Database ───────────────────────────────────────────────────────────────
# TURSO_DATABASE_URL=  # Default: file:/var/lib/zentity/web/dev.db
# TURSO_AUTH_TOKEN=

# ─── Admin ──────────────────────────────────────────────────────────────────
# ZENTITY_ADMIN_API_KEY=
