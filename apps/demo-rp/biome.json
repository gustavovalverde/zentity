{
  "extends": [
    "ultracite/biome/core",
    "ultracite/biome/react",
    "ultracite/biome/next"
  ],
  "linter": {
    "domains": {
      "next": "recommended"
    }
  },
  "files": {
    "includes": [
      "src/**",
      "e2e/**",
      "scripts/**",
      "*.ts",
      "*.mts",
      "!!node_modules",
      "!!.next",
      "!!.data",
      "!!playwright-report",
      "!!test-results"
    ]
  },
  "overrides": [
    {
      "includes": ["src/components/ui/**/*.tsx"],
      "linter": {
        "rules": {
          "a11y": {
            "noLabelWithoutControl": "off",
            "noNoninteractiveElementInteractions": "off",
            "noSvgWithoutTitle": "off",
            "useFocusableInteractive": "off",
            "useKeyWithClickEvents": "off",
            "useSemanticElements": "off"
          },
          "correctness": {
            "noUnusedVariables": "off"
          },
          "performance": {
            "noNamespaceImport": "off"
          },
          "style": {
            "useImportType": "off",
            "noNestedTernary": "off"
          },
          "suspicious": {
            "noArrayIndexKey": "off"
          },
          "nursery": {
            "noShadow": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/components/exchange/**/*.tsx",
        "src/components/wine/**/*.tsx"
      ],
      "linter": {
        "rules": {
          "a11y": {
            "noLabelWithoutControl": "off",
            "noSvgWithoutTitle": "off"
          },
          "style": {
            "noNestedTernary": "off"
          }
        }
      }
    },
    {
      "includes": ["src/app/**/page.tsx"],
      "linter": {
        "rules": {
          "style": {
            "noNestedTernary": "off"
          }
        }
      }
    }
  ],
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json"
}
