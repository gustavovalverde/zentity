{
  "name": "landing",
  "private": true,
  "version": "0.0.0",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "pnpm": {
    "overrides": {
      "hono": ">=4.12.7",
      "@hono/node-server": ">=1.19.10",
      "dompurify": ">=3.3.2",
      "express-rate-limit": ">=8.2.2"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "biome check . --write",
