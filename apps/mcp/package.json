{
  "name": "@zentity/mcp-server",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "bin": {
    "zentity-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node --format esm && printf '#!/usr/bin/env node\\n' | cat - dist/index.js > dist/tmp && mv dist/tmp dist/index.js && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --transport http",
    "lint": "pnpm exec ultracite fix",
    "lint:check": "pnpm exec ultracite check",
    "lint:fix": "pnpm exec ultracite fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "bun run scripts/e2e-smoke.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@serenity-kit/opaque": "^1.1.0",
    "hono": "^4.12.14",
    "jose": "^6.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "ultracite": "7.3.2",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "overrides": {
      "vite": "7.3.2",
      "path-to-regexp": "^8.4.0",
      "picomatch@<2.3.2": "^2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4",
      "brace-expansion@<1.1.13": "^1.1.13",
      "brace-expansion@>=2 <5.0.5": "^5.0.5"
    }
  }
}
