# Zentity Web — Environment Variables
# Run `pnpm setup` to auto-generate secrets and initialize the database.

# ─── Required (auto-generated by `pnpm setup`) ──────────────────────────────
BETTER_AUTH_SECRET=
OPAQUE_SERVER_SETUP=
NEXT_PUBLIC_OPAQUE_SERVER_PUBLIC_KEY=
INTERNAL_SERVICE_TOKEN=
BBS_ISSUER_SECRET=
DEDUP_HMAC_SECRET=
PAIRWISE_SECRET=
CLAIM_SIGNING_SECRET=
CIPHERTEXT_HMAC_SECRET=
# KEY_ENCRYPTION_KEY=                   # Optional in dev, required in production (min 32 chars)

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
TURSO_DATABASE_URL=file:./.data/dev.db
MCP_PUBLIC_URL=http://localhost:3300
# TURSO_AUTH_TOKEN=               # Only for remote Turso

# ─── Feature Flags ───────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_FHEVM=true
NEXT_PUBLIC_ENABLE_HARDHAT=false

# ─── Services (defaults work for local dev) ──────────────────────────────────
# FHE_SERVICE_URL=http://localhost:5001
# OCR_SERVICE_URL=http://localhost:5004
# SIGNER_COORDINATOR_URL=http://localhost:5002
# SIGNER_ENDPOINTS=http://localhost:5101,http://localhost:5102,http://localhost:5103
# TRUSTED_ORIGINS=                # Comma-separated additional origins

# ─── Agent Attestation ───────────────────────────────────────────────────────
TRUSTED_AGENT_ATTESTERS=http://localhost:3102/api/jwks

# ─── Recovery (ML-KEM-768) ───────────────────────────────────────────────────
# In production set RECOVERY_ML_KEM_SECRET_KEY (base64 of 2400 bytes).
# In dev, a key is auto-generated at .data/recovery-key.bin.
# RECOVERY_ML_KEM_SECRET_KEY=

# ─── Blockchain — Registrar Wallets ──────────────────────────────────────────
# Generate with: cast wallet new
# REGISTRAR_PRIVATE_KEY=          # Global fallback
# LOCAL_REGISTRAR_PRIVATE_KEY=    # Hardhat
# FHEVM_REGISTRAR_PRIVATE_KEY=    # Sepolia fhEVM

# ─── Blockchain — fhEVM (Sepolia) ───────────────────────────────────────────
# Network params (chain ID, explorer, provider) are hardcoded for Sepolia.
# Only the RPC URL is configurable (switch providers for reliability/rate limits).
NEXT_PUBLIC_FHEVM_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Contract addresses (from zentity-fhevm-contracts deployment)
FHEVM_IDENTITY_REGISTRY=0x05c6FB879BbF0Cab2B0206523583F94E49Ba62e2
FHEVM_COMPLIANCE_RULES=0x78dE340fc7A6ba470a5dD8b0a5f5933cD48dC164
FHEVM_COMPLIANT_ERC20=0x2CBEF5Da4F16346bBb34C3D7a81bFC0D9882c711

# ─── Blockchain — Local Hardhat ──────────────────────────────────────────────
LOCAL_RPC_URL=http://127.0.0.1:8545
LOCAL_IDENTITY_REGISTRY=0x5FbDB2315678afecb367f032d93F642f64180aa3
LOCAL_COMPLIANCE_RULES=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0
LOCAL_COMPLIANT_ERC20=0xCf7Ed3AccA5a467e9e704C703E8D87F634fB0Fc9

# ─── Reown AppKit (Wallet Connection) ────────────────────────────────────────
NEXT_PUBLIC_PROJECT_ID=your-project-id-here

# ─── Optional Integrations ───────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GENERIC_OAUTH_PROVIDERS=[]      # JSON array

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Auto-generated by `pnpm setup`. Required for push notifications.
VAPID_PUBLIC_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:notifications@zentity.xyz

# ─── Email ───────────────────────────────────────────────────────────────────
# MAILPIT_BASE_URL=http://localhost:8025
# RESEND_API_KEY=                 # Production email delivery
# MAIL_FROM_EMAIL=no-reply@zentity.local
# MAIL_FROM_NAME=Zentity

# ─── Observability ───────────────────────────────────────────────────────────
# LOG_LEVEL=info
# OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_SERVICE_NAME=zentity-web

# ─── Custodial Recovery ─────────────────────────────────────────────────────
# CUSTODIAL_SIGNER_URL=                 # Zero-friction recovery signer URL
# CUSTODIAL_SIGNER_ID=                  # Signer ID for custodial signer

# ─── Misc ────────────────────────────────────────────────────────────────────
# ZENTITY_ADMIN_API_KEY=                # Protects admin tRPC routes
# DEMO_MODE=false
