{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "server.mjs",
    "src/lib/identity/liveness/socket.ts",
    "vitest.global-setup.ts",
    "vitest.setup.mts"
  ],
  "ignoreIssues": {
    "src/components/ui/**": ["exports", "types"],
    "src/components/vault-unlock.tsx": ["exports", "types"],
    "src/lib/auth/oidc/cimd.ts": ["exports", "types"],
    "src/lib/auth/oidc/disclosure/delivery.ts": ["exports"],
    "src/lib/auth/oidc/step-up.ts": ["exports"],
    "src/lib/blockchain/attestation/providers.ts": ["exports", "types"],
    "src/lib/terminology.ts": ["exports"],
    "src/lib/db/queries/attestation.ts": ["exports"],
    "src/lib/identity/liveness/human/server.ts": ["exports"],
    "src/lib/observability/client-metrics.ts": ["types"],
    "src/lib/trpc/routers/recovery.ts": ["exports"],
    "src/lib/trpc/routers/zk.ts": ["exports"]
  },
  "ignore": [
    "scripts/**",
    "playwright.config.mts",
    "public/coi-serviceworker.js",
    "public/push-sw.js",
    "e2e/**",
    "src/test-utils/**",
    "src/**/*.d.ts"
  ],
  "ignoreDependencies": [
    "@commitlint/cli",
    "@commitlint/config-conventional",
    "@vladmandic/human-models",
    "@synthetixio/synpress-cache",
    "buffer",
    "pino-pretty",
    "socket.io",
    "tailwindcss",
    "tfhe",
    "tw-animate-css"
  ],
  "ignoreBinaries": ["nargo"],
  "vitest": {
    "config": ["vitest.config.mts", "vitest.unit.config.mts"]
  }
}
