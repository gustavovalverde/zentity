{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "server.mjs",
    "src/lib/identity/liveness/socket/*.ts",
    "vitest.global-setup.ts",
    "vitest.setup.mts"
  ],
  "ignoreIssues": {
    "src/components/ui/**": ["exports", "types"],
    "src/lib/copy-constants.ts": ["exports"],
    "src/lib/db/queries/attestation.ts": ["exports"],
    "src/lib/identity/liveness/human-server.ts": ["exports"]
  },
  "ignore": [
    "scripts/**",
    "playwright.config.mts",
    "public/coi-serviceworker.js",
    "public/push-sw.js",
    "e2e/**",
    "src/test/**"
  ],
  "ignoreDependencies": [
    "@commitlint/cli",
    "@commitlint/config-conventional",
    "@vladmandic/human-models",
    "@synthetixio/synpress-cache",
    "buffer",
    "pino-pretty",
    "socket.io",
    "tailwindcss",
    "tfhe",
    "tw-animate-css"
  ],
  "ignoreBinaries": ["nargo"],
  "vitest": {
    "config": ["vitest.config.mts", "vitest.unit.config.mts"]
  }
}
