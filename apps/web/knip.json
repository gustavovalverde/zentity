{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "exclude": ["types"],
  "ignore": [
    "src/components/ui/**",
    "scripts/**",
    "public/coi-serviceworker.js",
    "public/push-sw.js",
    "e2e/**",
    "vitest.unit.config.mts",
    "src/test/client-only.ts",
    "src/test/server-only.ts"
  ],
  "ignoreDependencies": [
    "@vladmandic/human-models",
    "tfhe",
    "pino-pretty",
    "lint-staged",
    "@synthetixio/synpress-cache",
    "fs-extra",
    "@types/fs-extra",
    "buffer"
  ],
  "ignoreBinaries": ["nargo"],
  "entry": [
    "src/app/**/page.{ts,tsx}",
    "src/app/**/layout.{ts,tsx}",
    "src/app/**/route.{ts,tsx}",
    "src/**/*.test.{ts,tsx}",
    "src/**/*.integration.test.{ts,tsx}"
  ]
}
