{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "rules": {
    "types": "warn"
  },
  "ignoreIssues": {
    "src/components/ui/**": ["exports", "types"]
  },
  "ignore": [
    "scripts/**",
    "public/coi-serviceworker.js",
    "public/push-sw.js",
    "e2e/**",
    "src/test/client-only.ts",
    "src/test/server-only.ts"
  ],
  "ignoreDependencies": [
    "@vladmandic/human-models",
    "tfhe",
    "pino-pretty",
    "lint-staged",
    "@synthetixio/synpress-cache",
    "fs-extra",
    "@types/fs-extra",
    "buffer"
  ],
  "ignoreBinaries": ["nargo"],
  "vitest": {
    "config": ["vitest.config.mts", "vitest.unit.config.mts"]
  }
}
