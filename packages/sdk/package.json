{
  "name": "@zentity/sdk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/**/*.map",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/protocol/index.ts src/rp/index.ts --format esm,cjs --dts --sourcemap --clean --out-dir dist",
    "build:watch": "tsup src/index.ts src/protocol/index.ts src/rp/index.ts --format esm,cjs --dts --sourcemap --watch --out-dir dist",
    "clean": "rm -rf dist",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "jose": "^6.2.1"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./protocol": {
      "import": {
        "types": "./dist/protocol/index.d.ts",
        "default": "./dist/protocol/index.js"
      },
      "require": {
        "types": "./dist/protocol/index.d.cts",
        "default": "./dist/protocol/index.cjs"
      }
    },
    "./rp": {
      "import": {
        "types": "./dist/rp/index.d.ts",
        "default": "./dist/rp/index.js"
      },
      "require": {
        "types": "./dist/rp/index.d.cts",
        "default": "./dist/rp/index.cjs"
      }
    },
    "./package.json": "./package.json"
  }
}
